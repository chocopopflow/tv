		try {
			document.querySelectorAll('.canal-btn').forEach(function(b){ b.classList.remove('active'); });
			var btn = document.getElementById('CID' + ch.m3u8);
			if (btn) { btn.classList.add('active'); btn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' }); }
		} catch (e) {}
		Player(ch.url, ch.name, ch.poster);
	}

	function HandleRemote(event) {
		var code = event.keyCode || event.which;
		var key  = event.key || '';
		if (key === 'ChannelUp' || code === 427 || key === 'PageUp' || code === 33 || key === 'ArrowUp' || code === 38 || code === 19) {event.preventDefault(); changeChannel(-1); return;}
		if (key === 'ChannelDown' || code === 428 || key === 'PageDown' || code === 34 || key === 'ArrowDown' || code === 40 || code === 20) {event.preventDefault(); changeChannel(+1); return;}
	}
	
	try {
		var chan = window.location.hash ? window.location.hash.substr(1) : '';
		var found = false;
		if (chan && typeof Streams !== 'undefined') {
			for (var i = 0; i < Streams.length; i++) {
				if (Streams[i].m3u8 === chan) { currentChannelM3U8 = chan; found = true; break; }
			}
		}
		if (!found && Streams && Streams.length > 0) { currentChannelM3U8 = Streams[0].m3u8; }
	} catch (e) {
		try { if (Streams && Streams.length > 0) { currentChannelM3U8 = Streams[0].m3u8; } } catch (_) {}
	}

	if(Streams != null){ Chanels(chan); } Smenu();

	// Scroll al canal activo en el carrusel al inicio
	try {
		var initBtn = document.getElementById('CID' + (chan || currentChannelM3U8));
		if (initBtn) { setTimeout(function(){ initBtn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' }); }, 500); }
	} catch(e) {}

	function SendError(message) { return; }

	window.onload = function () {
		document.oncontextmenu = function(){return false;}
		try {video.removeAttribute('controls');} catch(e) {}
		if (player.addEventListener){
			video.addEventListener("playing", Playing);		
			video.addEventListener("waiting", Waiting);		
			video.addEventListener("interruptend", Serror);
			video.addEventListener("error", Serror);
			video.addEventListener("progress", Progress);
			video.addEventListener('play', Hplay);
			try {document.addEventListener("keyup", Menu);} catch(e) {}
			try {document.addEventListener("touchstart", Menu);} catch(e) {}
			try {document.addEventListener("mousemove", Menu);} catch(e) {}
			try {window.addEventListener("keypress", HandleRemote);} catch(e) {}
			try {window.addEventListener("keydown", HandleRemote);} catch(e) {}
		}
		setInterval(Timeupdate, 1000);
	}
</script>
</body>
