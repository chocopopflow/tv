	function setTitle(str){head.innerHTML = '<a href="javascript:window.history.back();"><i class="material-icons">&#xe5cb;</i></a><span>' + str + '</span>'; document.title = str;}

	function Player(source, name, poster){
		Herror(); Swait(); title = name; setTitle(title); fatalerror = null; 
		setTimeout(clearHashFromUrl, 100);
		try {
			document.querySelectorAll('.canal-btn').forEach(function(b){ b.classList.remove('active'); });
			var ch = null, i;
			for (i = 0; i < Streams.length; i++) {
				if (Streams[i].name === name || Streams[i].url === source) { ch = Streams[i]; break; }
			}
			if (ch) {
				var btn = document.getElementById('CID' + ch.m3u8);
				if (btn) {
					btn.classList.add('active');
					btn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
				}
				currentChannelM3U8 = ch.m3u8;
			}
		} catch (e) {}
		error.innerHTML = '<h3>EL CANAL NO ESTÁ DISPONIBLE, INTENTA MAS TARDE.</h3>';
		try {hls.destroy(); hls.detachMedia();} catch(e) {}
		if(session){destroy();}
		var type = "video/mp4";
		if(source.match(/.webm/i)){type = "video/webm";}
		if(source.match(/.mp3/i)){type = "audio/mpeg";}
		if(source.match(/.aac/i)){type = "audio/mp4";}
		if(source.match(/.mp4/i)){type = "video/mp4";}
		if(source.match(/.m3u8/i)){type = "application/vnd.apple.mpegurl";}
		if(poster != null) try {video.poster = poster;} catch(e) {video.poster = '';} else {video.poster = '';}
		if (_playerDelayId) { clearTimeout(_playerDelayId); }
		_playerDelayId = setTimeout(function () {
			_playerDelayId = null;
			var isHlsSupported = (typeof window.Hls !== 'undefined' && typeof Hls.isSupported === 'function' && Hls.isSupported());
			if (isHlsSupported && (/\.m3u8/i).test(source)) {
				hls = new Hls({manifestLoadingTimeOut: 2e4, manifestLoadingMaxRetry: 4});
				hls.autoLevelEnabled = true;
				hls.bandwidthEstimate = 2500000;
				hls.loadSource(source);
				hls.attachMedia(video);
				hls.on(Hls.Events.MANIFEST_PARSED, function() {Playing(); Play();});
				hls.on(Hls.Events.ERROR, function (event, data) {
					if(data.fatal){
						switch(data.type){
							case Hls.ErrorTypes.MEDIA_ERROR: hls.recoverMediaError(); break;
							default: hls.destroy(); Serror(); break;
						}
					}
				});
				return;
			}
			if(video.canPlayType(type)){video.src = source; video.load(); video.addEventListener('loadedmetadata',function() {Playing(); Play();}); return;}
			error.innerHTML = '<h3>CONTENIDO NO SOPORTADO POR EL NAVEGADOR</h3>';
			Serror();
		}, 1000);
	}

	// Construye el carrusel y también mantiene la lista oculta para compatibilidad
	function Chanels(chanel){
		var carouselEl = document.getElementById('canal-carousel');
		Streams.forEach(function(element){
			// Carrusel
			var btn = document.createElement('a');
			btn.id = 'CID' + element['m3u8'];
			btn.className = 'canal-btn';
			btn.href = 'javascript:void(0)';
			btn.innerHTML = '<img src="' + element['poster'] + '" alt="' + element['name'] + '" onerror="this.style.display=\'none\'"><span>' + element['name'] + '</span>';
			btn.onclick = (function(el){ return function(){ Player(el['url'], el['name'], el['poster']); }; })(element);
			carouselEl.appendChild(btn);

			// Lista vieja (oculta)
			elmnt.innerHTML += '<a id="ID'+element['m3u8']+'" onclick="Player('+"'"+element['url']+"','"+element['name']+"','"+element['poster']+"'"+')" href="javascript:void(0)" class="listepic-link"> '+ element['name'] +' </a>';

			if(element['m3u8'] == chanel){source = element['url']; title = element['name']; poster = element['poster'];}
		});
		if(source){Player(source, title, poster);}
	}
	
