	<style>
.material-icons { vertical-align:-25%; font-size: 50px; color: white;}
body {	background-color: #000; height: 100%; width: 100%; margin: 0; padding: 0; position: absolute; overflow: hidden; }

/* VIDEO ocupa todo menos el carrusel de abajo */
video {
  position: absolute;
  top: 0; right: 0; left: 0;
  bottom: 130px; /* espacio para el carrusel */
  margin: auto;
  width: 100%;
  height: calc(100% - 130px);
  z-index: 1;
  object-fit: contain;
}

video::-internal-media-controls-overlay-cast-button {display: none;}

.loading {position: absolute;top: 0;right: 0;bottom: 130px;left: 0;margin: auto;width: 200px;height: 200px;z-index: 5;-webkit-animation:spin 1s linear infinite;-moz-animation:spin 1s linear infinite;animation:spin 1s linear infinite;}
@-moz-keyframes spin { 100% { -moz-transform: rotate(360deg); } }
@-webkit-keyframes spin { 100% { -webkit-transform: rotate(360deg); } }
@keyframes spin { 100% { -webkit-transform: rotate(360deg); transform:rotate(360deg); } }
.loader {position: absolute;top: 0;right: 0;bottom: 130px;left: 0;margin: auto;width: 200px;height: 200px;z-index: 5;}
svg path, svg rect{fill: #cd6a33;}

.error {position: absolute;top: 0;right: 0;bottom: 130px;left: 0;margin: auto;max-width: 300px;max-height: 200px;color: #cd6a33;z-index: 20 !important;text-align: center;background-color: rgba(0, 0, 0, 0.75);padding: 30px;}
.mcast {position: absolute;top: 0;right: 0;bottom: 130px;left: 0;margin: auto;max-width: 300px;max-height: 200px;color: #cd6a33;z-index: 20 !important;text-align: center;background-color: rgba(0, 0, 0, 0.75);padding: 30px;}

/* CONTROLES */
.controls {position: absolute;top: 0;bottom: 130px;right: 0;left: 0;margin: auto;width: 100%;height: calc(100% - 130px);color: white;z-index: 10 !important;padding: 10px;}
.controls-top {position: absolute;top: 0;right: 0;left: 0;text-align: left;background-color: rgba(0, 0, 0, 0.25);font-size: 2em;padding: 10px;}
.controls-top a:hover i , .controls-top a:focus i {background: rgba(204, 204, 204, 0.5);}
.controls-center {position: absolute;height: 10em;width: 10em;top: 0;bottom: 0;left: 0;right: 0;margin: auto;}
.controls-center a {display: inline-block;}
.controls-bottom {position: absolute;left: 0;right: 0;bottom: 0;}
.btn-screen {position: absolute;right: 0;bottom: 0;}
.controls-cast {position: absolute;right: 0;height: 50px;width: 50px;margin-right: 20px;}
a {text-decoration: none;text-shadow:2px 0 0 #000, -2px 0 0 #000,0 2px 0 #000, 0 -2px 0 #000, 1px 1px 0 #000, -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, 1px 1px 5px #000;}
.controls-bottom a {padding-left: 5px;padding-right: 5px;display: -webkit-box;display: -moz-box;display: -ms-inline-flexbox;display: -webkit-inline-flex;display: inline-flex;border-radius: 5px;}
.controls-bottom a h5 {margin-right: 5px;}
.controls-bottom a:hover, .controls-bottom a:focus {background: rgba(204, 204, 204, 0.5);}

/* ========================
   CARRUSEL HORIZONTAL
   ======================== */
#carousel-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 130px;
  z-index: 15;
  background: linear-gradient(to top, #0a0a0a, #111);
  border-top: 1px solid #2a2a2a;
  display: flex;
  align-items: center;
}

#canal-carousel {
  display: flex;
  overflow-x: auto;
  overflow-y: hidden;
  scroll-behavior: smooth;
  gap: 8px;
  padding: 8px 50px;
  height: 100%;
  align-items: center;
  -ms-overflow-style: none;
  scrollbar-width: none;
  flex: 1;
}
#canal-carousel::-webkit-scrollbar { display: none; }

.canal-btn {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80px;
  height: 108px;
  background: rgba(255,255,255,0.05);
  border: 1.5px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  cursor: pointer;
  transition: transform 0.15s, border-color 0.15s, background 0.15s;
  padding: 6px 4px;
  text-decoration: none;
  text-shadow: none;
  color: #ccc;
  font-size: 10px;
  text-align: center;
  font-family: sans-serif;
  box-sizing: border-box;
}
.canal-btn:hover {
  transform: scale(1.08);
  border-color: #cd6a33;
  background: rgba(205, 106, 51, 0.12);
  color: #fff;
  text-shadow: none;
}
.canal-btn.active {
  border-color: #cd6a33 !important;
  background: rgba(205, 106, 51, 0.25) !important;
  color: #fff !important;
}
.canal-btn img {
  width: 52px;
  height: 52px;
  object-fit: contain;
  margin-bottom: 5px;
  border-radius: 4px;
}
.canal-btn span {
  display: block;
  line-height: 1.2;
  max-width: 72px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Botones de scroll izq/der */
.scroll-arrow {
  position: absolute;
  top: 0; bottom: 0;
  width: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.6);
  border: none;
  color: #fff;
  font-size: 22px;
  cursor: pointer;
  z-index: 16;
  transition: background 0.2s;
}
.scroll-arrow:hover { background: rgba(205,106,51,0.5); }
.scroll-arrow.left  { left: 0;  border-right: 1px solid #2a2a2a; }
.scroll-arrow.right { right: 0; border-left:  1px solid #2a2a2a; }

/* Ocultar lista vieja */
.listepic { display: none !important; }

@media (max-width: 500px) {
  video { bottom: 110px; height: calc(100% - 110px); }
  #carousel-wrap { height: 110px; }
  .canal-btn { width: 68px; height: 94px; }
  .canal-btn img { width: 42px; height: 42px; }
}
